<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="payment_provider_havano" model="payment.provider">
        <field name="name">Havano Payments</field>
        <field name="code">havano_payments</field>
        <field name="state">disabled</field>
        <field name="is_published">True</field>
        <field name="redirect_form_view_id" ref="redirect_form"/>
        <field name="inline_form_view_id" ref="inline_form"/>
        <field name="image_128" type="base64" file="havano_payments/static/description/icon.png"/>
        <field name="payment_method_ids" eval="[
            (6, 0, [
                ref('payment_method_paynow'),
                ref('payment_method_ecocash')
            ])
        ]"/>
    </record>
</odoo>
